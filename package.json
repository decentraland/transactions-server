{
  "name": "transactions-server",
  "version": "1.0.0",
  "description": "Transactions server",
  "main": "dist/index.js",
  "scripts": {
    "lint": "tslint -p tsconfig.json",
    "lint:fix": "tslint -p tsconfig.json --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "watch:build": "tsc -p tsconfig.json --watch",
    "start": "npm run build && node --abort-on-uncaught-exception --unhandled-rejections=strict dist/index.js",
    "debug": "npm run build && node --inspect --abort-on-uncaught-exception --unhandled-rejections=strict dist/index.js",
    "start:watch": "nodemon src/index.ts",
    "test": "jest --forceExit --detectOpenHandles --coverage --verbose",
    "test:watch": "jest --watch --verbose",
    "migrate": "node-pg-migrate --database-url-var PG_COMPONENT_PSQL_CONNECTION_STRING --envPath .env -j ts --tsconfig tsconfig.json -m ./src/migrations",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx nano-staged",
    "pre-push": "npm run typecheck && npm test -- --no-coverage"
  },
  "nano-staged": {
    "*.{js,ts}": [
      "tslint",
      "prettier --check"
    ]
  },
  "keywords": [
    "decentraland"
  ],
  "author": "Decentraland",
  "license": "Apache-2.0",
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 80
  },
  "dependencies": {
    "@dcl/core-commons": "^0.10.1",
    "@dcl/features-component": "^1.0.1",
    "@dcl/fetch-component": "^1.1.0",
    "@dcl/http-requests-logger-component": "^1.0.0",
    "@dcl/http-server": "^2.0.2",
    "@dcl/http-tracer-component": "^2.0.1",
    "@dcl/metrics": "^1.0.1",
    "@dcl/pg-component": "^0.2.0",
    "@dcl/schemas": "^25.0.0",
    "@dcl/thegraph-component": "^0.1.1",
    "@dcl/traced-fetch-component": "^1.0.7",
    "@gelatocloud/gasless": "^0.0.12",
    "@well-known-components/env-config-provider": "^1.1.1",
    "@well-known-components/interfaces": "^1.5.2",
    "@well-known-components/logger": "^3.1.2",
    "@well-known-components/tracer-component": "^1.2.0",
    "ajv": "^8.6.0",
    "decentraland-transactions": "^2.17.0",
    "node-pg-migrate": "^7.9.1",
    "sql-template-strings": "^2.2.2",
    "typescript": "~5.3.0",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@dcl/test-helpers": "^0.2.0",
    "@types/node": "^20.3.2",
    "dcl-tslint-config-standard": "^2.0.0",
    "expect": "^26.6.2",
    "fetch-mock": "^9.11.0",
    "jest": "^29.7.0",
    "nano-staged": "^1.0.2",
    "nodemon": "^2.0.9",
    "prettier": "^2.3.2",
    "simple-git-hooks": "^2.13.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^9.1.1",
    "tslint": "^6.1.3",
    "tslint-plugin-prettier": "^2.3.0"
  }
}
